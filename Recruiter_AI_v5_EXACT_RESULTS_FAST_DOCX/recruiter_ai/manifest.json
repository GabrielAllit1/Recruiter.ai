{
  "manifest_version": 3,
  "name": "Recruiter.ai",
  "version": "5.0.0",
  "description": "Resume-first job matching with exact job cards, match score, ghost-job warning, and workplace links.",
  "action": { "default_popup": "popup.html", "default_title": "Recruiter.ai" },
  "icons": { "16":"icons/icon16.png", "32":"icons/icon32.png", "48":"icons/icon48.png", "128":"icons/icon128.png" },
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["https://remoteok.com/*", "https://www.arbeitnow.com/*", "https://www.google.com/*", "https://www.linkedin.com/*", "https://github.com/*", "https://orcid.org/*"]
}
